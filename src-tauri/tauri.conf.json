{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DesignForge",
  "version": "0.1.0",
  "identifier": "com.designforge.app",
  "build": {
    "beforeDevCommand": "node ./node_modules/vite/bin/vite.js --host 127.0.0.1 --port 1420",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "node ./scripts/build.mjs",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "DesignForge",
        "width": 1440,
        "height": 900,
        "minWidth": 1280,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"]
  }
}
